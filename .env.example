# Copy to .env (or export these) before running.

# --- Volcengine Ark (OpenAI-compatible) ---
ARK_API_KEY=
ARK_MODEL=deepseek-v4-flash
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# ARK_THINKING=disabled            # optional: disabled | enabled

# --- External LabBench2: code repo + dataset are TWO separate sources ---
# (1) Official eval CODE repo (scorers / assembly engine / question-file downloader).
#     git clone https://github.com/EdisonScientific/labbench2
LABBENCH_ROOT=/path/to/labbench2
# (2) DATASET root holding the question manifests (parquet). NOT bundled with the code repo.
#     Download from HuggingFace dataset EdisonScientific/labbench2 so that these exist:
#       $LABBENCH_DATA_ROOT/labbench2/seqqa2/train-00000-of-00001.parquet
#       $LABBENCH_DATA_ROOT/labbench2/cloning/train-00000-of-00001.parquet
#     e.g.  huggingface-cli download EdisonScientific/labbench2 \
#             --repo-type dataset --local-dir /path/to/benchmarks/labbench2
LABBENCH_DATA_ROOT=/path/to/benchmarks

# --- optional knobs ---
# AGENT_MAX_ROUNDS=14
# SEQQA_MAX_ROUNDS=6
# HTTP_TIMEOUT=180
